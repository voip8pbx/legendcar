{
    "name": "legendcar-monorepo",
    "version": "1.0.0",
    "description": "LegendCar - Classic Car Gallery Application",
    "private": true,
    "scripts": {
        "dev": "npx -y concurrently \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
        "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
        "start": "cd frontend && npm run start",
        "build:frontend": "cd frontend && npm run build",
        "build:backend": "cd backend && npm run build",
        "start:backend": "cd backend && npm run start",
        "lint": "cd frontend && npm run lint",
        "prepare": "npm install --workspace=frontend && npm install --workspace=backend"
    },
    "workspaces": [
        "frontend",
        "backend"
    ],
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}